{
  "buildCommand": "cd website/frontend && npm install && npm run build",
  "outputDirectory": "website/frontend/build",
  "functions": {
    "api/index.py": {
      "maxDuration": 60,
      "includeFiles": "website/{api,data}/**"
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index" },
    { "source": "/health", "destination": "/api/index" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
